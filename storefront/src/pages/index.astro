---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductGrid from '../components/ProductGrid.astro';
import { getCategories, getProducts } from '../lib/api';
import type { CategoryDTO, ProductSummaryDTO } from '../lib/types';

let categories: CategoryDTO[] = [];
let featured: ProductSummaryDTO[] = [];
let loadError: string | null = null;

try {
  const [categoriesResult, productsResult] = await Promise.all([
    getCategories(),
    getProducts({ size: 4 }),
  ]);
  categories = categoriesResult;
  featured = productsResult.content;
} catch (error) {
  loadError = error instanceof Error ? error.message : 'Failed to load data';
}
---

<BaseLayout title="ecommerce — Find your style">
  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">Find your style</h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
          Custom-designed apparel and accessories. Made on demand, shipped worldwide.
        </p>
        <div class="mt-8 flex justify-center gap-4">
          <a
            href="/products"
            class="inline-flex items-center rounded-md bg-gray-900 px-6 py-3 text-sm font-medium text-white shadow-sm transition-colors hover:bg-gray-800"
          >
            Shop all products
          </a>
        </div>
      </div>
    </div>
  </section>

  {
    loadError ? (
      <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="rounded-lg border border-red-200 bg-red-50 p-6 text-center">
          <p class="text-sm text-red-700">
            Could not load the storefront right now. Make sure the backend is running on{' '}
            <code class="rounded bg-red-100 px-1">http://localhost:8080</code>.
          </p>
          <p class="mt-2 text-xs text-red-600">{loadError}</p>
        </div>
      </section>
    ) : (
      <>
        <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
          <div class="mb-6 flex items-end justify-between">
            <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">
              Featured products
            </h2>
            <a href="/products" class="text-sm font-medium text-gray-700 hover:text-gray-900">
              View all &rarr;
            </a>
          </div>
          <ProductGrid products={featured} />
        </section>

        <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
          <div class="mb-6">
            <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">
              Shop by category
            </h2>
          </div>
          <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
            {categories.map((category) => (
              <a
                href={`/products?category=${category.slug}`}
                class="group flex flex-col items-center justify-center rounded-lg border border-gray-200 bg-white p-6 text-center shadow-sm transition-all hover:-translate-y-0.5 hover:border-gray-300 hover:shadow-md"
              >
                <span class="text-2xl font-semibold text-gray-900 group-hover:text-blue-600">
                  {category.name}
                </span>
                {category.description && (
                  <span class="mt-2 line-clamp-2 text-xs text-gray-500">
                    {category.description}
                  </span>
                )}
              </a>
            ))}
          </div>
        </section>
      </>
    )
  }
</BaseLayout>
