---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ecommerce — Find your style">
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">Find your style</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
        Custom-designed apparel and accessories. Made on demand, shipped worldwide.
      </p>
      <div class="mt-8 flex justify-center gap-4">
        <a
          href="/products"
          class="inline-flex items-center rounded-md bg-gray-900 px-6 py-3 text-sm font-medium text-white shadow-sm transition-colors hover:bg-gray-800"
        >
          Shop now
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
