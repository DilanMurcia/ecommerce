---
import Layout from '../layouts/Layout.astro';
import HelloReact from '../components/HelloReact.tsx';
---

<Layout title="Ecommerce POD — Hola mundo">
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-5xl font-bold text-blue-600">
      Hola mundo
    </h1>
    <p class="mt-4 text-lg text-gray-700">
      Storefront inicializado con Astro + Tailwind v4 + React islands.
    </p>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-2xl font-semibold text-gray-900">
        React island (prueba de hidratación)
      </h2>
      <p class="mt-2 text-sm text-gray-600">
        Este componente React es interactivo, pero el resto de la página es estático.
      </p>
      <div class="mt-4">
        <HelloReact client:load />
      </div>
    </section>
  </main>
</Layout>
