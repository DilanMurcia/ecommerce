---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Storefront' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ecommerce POD storefront" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <slot />
  </body>
</html>
