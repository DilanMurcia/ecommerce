---
const year = new Date().getFullYear();
const links = [
  { label: 'About', href: '#' },
  { label: 'Contact', href: '#' },
  { label: 'Terms', href: '#' },
  { label: 'Privacy', href: '#' },
];
---

<footer class="mt-16 border-t border-gray-200 bg-gray-50">
  <div
    class="mx-auto flex max-w-7xl flex-col items-center gap-4 px-4 py-8 text-sm text-gray-600 sm:flex-row sm:justify-between sm:px-6 lg:px-8"
  >
    <p>&copy; {year} ecommerce. All rights reserved.</p>
    <ul class="flex items-center gap-4">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="transition-colors hover:text-gray-900">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
