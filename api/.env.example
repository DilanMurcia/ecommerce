# Spring Boot reads these via spring-dotenv. Copy this file to .env and fill in real values.
# .env is gitignored. NEVER commit it.

# Neon PostgreSQL connection (https://neon.tech → your project → Connection Details)
# Format: jdbc:postgresql://HOST:5432/DBNAME?sslmode=require
DB_URL=jdbc:postgresql://YOUR-HOST.neon.tech:5432/YOUR-DB?sslmode=require
DB_USER=YOUR_USER
DB_PASSWORD=YOUR_PASSWORD
